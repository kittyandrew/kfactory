+// kfactory: read the access token from the shared launcher cache when
+// no explicit bearer / env var is provided. Single source of truth is
+// `~/.config/kfactory/auth.json` (path passed via
+// OPENCODE_SERVER_BEARER_CACHE_PATH). Catches the case where kfactory
+// rotated the token between the launcher's exec and the SDK's first
+// request.
+//
+// Warn-throttling is keyed on the actual failure message: a recovered
+// state (cache file fixed) then a fresh failure (cache file broken
+// again) BOTH surface. Server-lifetime "warn once and never again" was
+// the original shape and made transient cache breaks invisible to
+// operators (a TUI restart was the only signal).
+const bearerFromCacheWarnedMessages = new Set<string>()
+function bearerFromCache(): string | undefined {
+  const p = Flag.OPENCODE_SERVER_BEARER_CACHE_PATH
+  if (!p) return undefined
+  try {
+    const json = JSON.parse(readFileSync(p, "utf8")) as { access_token?: string }
+    bearerFromCacheWarnedMessages.clear()
+    return json.access_token
+  } catch (err) {
+    const key = String(err)
+    if (!bearerFromCacheWarnedMessages.has(key)) {
+      bearerFromCacheWarnedMessages.add(key)
+      console.warn(`bearerFromCache: parse failed at ${p}: ${err}`)
+    }
+    return undefined
+  }
+}
+
