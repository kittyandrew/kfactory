@@ -0,0 +1,185 @@
+// kfactory: refresh-aware fetch wrapper + refresh-hint pub/sub.
+//
+// Lives in @opencode-ai/core because BOTH sides of the seam need it and
+// they no longer share a package: `opencode attach`
+// (packages/opencode/src/cli/cmd/attach.ts) constructs the fetch
+// wrapper, while the TUI App (packages/tui/src/app.tsx) subscribes to
+// refresh hints for its error toast -- and packages/tui does not depend
+// on packages/opencode. core's wildcard `"./*"` export makes this
+// importable from both as `@opencode-ai/core/kfactory-bearer-refresh`.
+//
+// Token refresh is delegated to the launcher (`kfactory`) via
+// subprocess; this module just reads `~/.config/kfactory/auth.json`
+// (path passed in OPENCODE_SERVER_BEARER_CACHE_PATH) and spawns
+// `kfactory auth refresh` when the access token is near expiry.
+// kfactory owns the lockfile + IdP HTTP + atomic-rename + AuthFile
+// schema -- see cmd/kfactory/auth.go:runAuthRefresh.
+//
+// Why delegate instead of refreshing in-TS: docs/spec.md's
+// "Subprocess-delegated token refresh" decision entry (kfactory repo).
+import { readFileSync } from "fs"
+import { spawn } from "child_process"
+import { stripVTControlCharacters } from "util"
+
+// Subscription channel for refresh outcomes. The fetch wrapper runs
+// outside the TUI component tree (the SDK calls it with a Request
+// object); to surface a hint to the operator we publish into this
+// channel and the TUI subscribes from inside its component tree (see
+// packages/tui/src/app.tsx).
+export type RefreshHint = { kind: "not_logged_in" | "spawn_error" | "other_error"; detail: string }
+const refreshHintSubscribers = new Set<(hint: RefreshHint) => void>()
+export function onBearerRefreshHint(cb: (hint: RefreshHint) => void): () => void {
+  refreshHintSubscribers.add(cb)
+  return () => {
+    refreshHintSubscribers.delete(cb)
+  }
+}
+
+// Shared schema (authoritative def: tokenFile struct in
+// cmd/kfactory/auth.go). We only consume schema_version + access_token
+// + expires_at on this side; other fields are opaque. The version is
+// asserted on every read -- a kfactory build that bumps the schema
+// without a matching TUI rebuild surfaces here as a clear error rather
+// than a silent field-misread. See docs/spec.md §4 for the contract.
+const AUTH_FILE_SCHEMA_VERSION = 1
+interface AuthFile {
+  schema_version: number
+  access_token: string
+  expires_at: string // RFC3339
+}
+
+const REFRESH_SKEW_MS = 30_000
+const REFRESH_TIMEOUT_MS = 30_000
+
+export function readAuthFile(p: string): AuthFile {
+  const parsed = JSON.parse(readFileSync(p, "utf8")) as AuthFile
+  if (parsed.schema_version !== AUTH_FILE_SCHEMA_VERSION) {
+    throw new Error(
+      `auth.json schema_version ${String(parsed.schema_version)} != supported ${AUTH_FILE_SCHEMA_VERSION}; ` +
+        `update kfactory or opencode together`,
+    )
+  }
+  if (typeof parsed.access_token !== "string" || parsed.access_token === "") {
+    throw new Error("auth.json access_token is missing")
+  }
+  if (!Number.isFinite(new Date(parsed.expires_at).getTime())) {
+    throw new Error("auth.json expires_at is invalid")
+  }
+  return parsed
+}
+
+function isExpired(a: AuthFile): boolean {
+  return new Date(a.expires_at).getTime() <= Date.now() + REFRESH_SKEW_MS
+}
+
+// Outcome of a spawnKfactoryRefresh round-trip. We surface the discrete
+// failure modes (binary missing, refresh_token expired, generic error)
+// so the caller can decide whether to log once, log every time, or
+// surface a reattach prompt to the operator.
+interface RefreshOutcome {
+  status: "ok" | "not_logged_in" | "spawn_error" | "other_error"
+  stderr: string
+}
+
+// Spawn `kfactory auth refresh` and wait for it to exit. We capture
+// stderr (don't inherit it -- inheriting would let kfactory write raw
+// text into the TUI's alternate screen mid-render, corrupting it).
+//
+// Exit codes are a cross-component contract with the Go side. Authoritative
+// definitions live in cmd/kfactory/exit.go. Mirror them here:
+//   KFACTORY_EXIT_OK             = 0  // auth.json holds a fresh token
+//   KFACTORY_EXIT_NOT_LOGGED_IN  = 1  // refresh_token rejected; reattach needed
+//   KFACTORY_EXIT_OTHER          = 2  // network / fs / non-credential failure
+// Any new exit code on the Go side MUST update both constants below AND
+// the switch in spawnKfactoryRefresh.
+// child.on('error') fires for ENOENT (kfactory binary not on PATH) etc.
+const KFACTORY_EXIT_OK = 0
+const KFACTORY_EXIT_NOT_LOGGED_IN = 1
+function spawnKfactoryRefresh(): Promise<RefreshOutcome> {
+  return new Promise((resolve) => {
+    const child = spawn("kfactory", ["auth", "refresh"], {
+      stdio: ["ignore", "ignore", "pipe"],
+    })
+    const chunks: Buffer[] = []
+    child.stderr?.on("data", (chunk: Buffer) => chunks.push(chunk))
+    const timer = setTimeout(() => {
+      child.kill("SIGTERM")
+    }, REFRESH_TIMEOUT_MS)
+    child.on("exit", (code) => {
+      clearTimeout(timer)
+      const stderr = Buffer.concat(chunks).toString("utf8").trim()
+      if (code === KFACTORY_EXIT_OK) resolve({ status: "ok", stderr })
+      else if (code === KFACTORY_EXIT_NOT_LOGGED_IN) resolve({ status: "not_logged_in", stderr })
+      else resolve({ status: "other_error", stderr })
+    })
+    child.on("error", (err) => {
+      clearTimeout(timer)
+      resolve({ status: "spawn_error", stderr: String(err) })
+    })
+  })
+}
+
+export function createBearerRefreshFetch(cachePath: string): typeof fetch {
+  let currentBearer = readAuthFile(cachePath).access_token
+  let refreshing: Promise<void> | null = null
+  // Surface a given failure mode at most once per TUI session so the
+  // alternate screen isn't spammed on every request when kfactory is
+  // broken or the refresh_token is dead.
+  const warned = new Set<RefreshHint["kind"]>()
+
+  async function ensureFresh() {
+    if (refreshing) {
+      await refreshing
+      return
+    }
+    const auth = readAuthFile(cachePath)
+    if (!isExpired(auth)) {
+      currentBearer = auth.access_token
+      return
+    }
+    refreshing = (async () => {
+      try {
+        const outcome = await spawnKfactoryRefresh()
+        if (outcome.status !== "ok") {
+          if (!warned.has(outcome.status)) {
+            warned.add(outcome.status)
+            const detail = stripVTControlCharacters(outcome.stderr)
+            for (const cb of refreshHintSubscribers) {
+              cb({ kind: outcome.status, detail })
+            }
+          }
+          throw new Error(`kfactory auth refresh failed: ${outcome.status}`)
+        }
+        const refreshed = readAuthFile(cachePath)
+        currentBearer = refreshed.access_token
+      } finally {
+        refreshing = null
+      }
+    })()
+    await refreshing
+  }
+
+  // Cast via unknown: our wrapper is the call-signature of fetch, but
+  // Bun's typeof fetch also requires a `preconnect` static method we
+  // don't replicate (the SDK never invokes it on a custom fetch).
+  return (async (input: Parameters<typeof fetch>[0], init?: Parameters<typeof fetch>[1]) => {
+    await ensureFresh()
+    // @WARNING: do NOT pass `init.headers` alone -- when `input` is a
+    //    Request (the openapi-ts SDK calls our fetch this way), `fetch`
+    //    treats init.headers as a full override and discards EVERY header
+    //    the Request was built with (Content-Type, Content-Length,
+    //    x-opencode-workspace, x-opencode-directory, etc). The worker then
+    //    sees a POST with no Content-Type and an unparseable body -> 400
+    //    `kind=Payload reason="Expected object, got undefined"`. Merge
+    //    Request headers FIRST, then init.headers, then our Authorization.
+    const merged = new Headers()
+    if (input instanceof Request) {
+      input.headers.forEach((v, k) => merged.set(k, v))
+    }
+    if (init?.headers) {
+      new Headers(init.headers).forEach((v, k) => merged.set(k, v))
+    }
+    merged.set("Authorization", `Bearer ${currentBearer}`)
+    return fetch(input, { ...init, headers: merged })
+  }) as unknown as typeof fetch
+}
