+// kfactory: bus event published on every SSE subscriber attach / detach,
+// carrying the ABSOLUTE per-workspace count (not a delta). The instance
+// bus is workspace-scoped (one per InstanceStore context), so each
+// publish only reaches the plugin running in the same workspace.
+// Plugins that want to gate notifications on "is anyone watching" set
+// their local count to `props.count`. Absolute-count semantics removes
+// the cold-start asymmetry inherent to delta accumulation (a plugin
+// that loads after a subscriber attached can't reconstruct state from
+// deltas alone). See plugins/ntfy in the kfactory repo for the
+// canonical consumer.
+// Exported so handlers/global.ts can join the SAME counter when the
+// TUI in attach mode hits `/global/event` with an x-opencode-workspace
+// header. The workspace-routing middleware forwards such requests to
+// the workspace's instance context, so Bus.Service resolves to the
+// per-workspace bus -- adjusting + publishing on it from EITHER
+// endpoint lands in the same WeakMap entry. Separate trackers would
+// silently desync when an operator disconnects from one endpoint
+// while still subscribed to the other (subscriberCount flaps to 0
+// when one of two attached subscribers detaches, defeating the
+// suppress-on-connect intent).
+export const SubscribersChanged = BusEvent.define(
+  "kfactory.subscribers.changed",
+  Schema.Struct({ count: Schema.Number }),
+)
+
+// Per-instance subscriber-count tracker. Keyed by Bus.Interface, which is
+// minted once per InstanceState.make per workspace -- so the WeakMap
+// entry's lifetime matches the bus's, and a disposed instance's count
+// is GC'd along with the bus reference. Module-scope `let count = 0`
+// would be process-global and wrong for multi-workspace hosts.
+const subscriberCounts = new WeakMap<Bus.Interface, number>()
+
+export function adjustSubscriberCount(bus: Bus.Interface, delta: number): number {
+  const next = Math.max(0, (subscriberCounts.get(bus) ?? 0) + delta)
+  subscriberCounts.set(bus, next)
+  return next
+}
