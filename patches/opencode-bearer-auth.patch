--- a/packages/opencode/src/cli/cmd/tui/attach.ts
+++ b/packages/opencode/src/cli/cmd/tui/attach.ts
@@ -5,6 +5,176 @@ import { TuiConfig } from "@/cli/cmd/tui/config/tui"
