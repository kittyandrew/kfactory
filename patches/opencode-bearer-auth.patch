+    return json.access_token
+  } catch (err) {
+    if (!bearerFromCacheWarned) {
+      bearerFromCacheWarned = true
+      console.warn(`bearerFromCache: parse failed at ${p}: ${err}`)
+    }
+    return undefined
+  }
