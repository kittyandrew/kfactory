+import { Flag } from "@opencode-ai/core/flag/flag"
+import { readFileSync } from "fs"
+import { spawn } from "child_process"
+import { stripVTControlCharacters } from "util"
+
+// Subscription channel for refresh outcomes. The fetch wrapper runs
+// outside React context (SDK calls it with a Request object); to surface
+// a hint to the TUI we publish into this channel and the TUI subscribes
+// from inside its component tree (see ../app.tsx).
+type RefreshHint = { kind: "not_logged_in" | "spawn_error" | "other_error"; detail: string }
+const refreshHintSubscribers = new Set<(hint: RefreshHint) => void>()
+export function onBearerRefreshHint(cb: (hint: RefreshHint) => void): () => void {
+  refreshHintSubscribers.add(cb)
+  return () => {
+    refreshHintSubscribers.delete(cb)
+  }
+}
+
+// kfactory: refresh-aware fetch wrapper. Token refresh is
+// delegated to the launcher (`kfactory`) via subprocess; this file just
+// reads `~/.config/kfactory/auth.json` (path passed in
+// OPENCODE_SERVER_BEARER_CACHE_PATH) and spawns `kfactory auth refresh`
+// when the access token is near expiry. kfactory owns the lockfile +
+// Zitadel HTTP + atomic-rename + AuthFile schema -- see
+// cmd/kfactory/auth.go:runAuthRefresh.
+//
+// Why delegate instead of refreshing in-TS:
+//   - Single source of truth: refresh logic lives in one place (Go),
+//     used by both `kfactory list/dispatch/attach` and the TUI here.
+//   - Cross-process safety: kfactory's ensureFresh already locks the
+//     auth.json so concurrent TUIs / kfactory CLI invocations don't
+//     race the refresh_token rotation.
+//   - Smaller patch surface: no HTTP, no flock, no schema dup in TS.
+//
+// Schema (set by kfactory): Go time.Time JSON encodes expires_at as RFC3339.
+interface AuthFile {
+  access_token: string
+  expires_at: string // RFC3339
+}
+
+const REFRESH_SKEW_MS = 30_000
+const REFRESH_TIMEOUT_MS = 30_000
+
+function readAuthFile(p: string): AuthFile {
+  return JSON.parse(readFileSync(p, "utf8")) as AuthFile
+}
+
+function isExpired(a: AuthFile): boolean {
+  return new Date(a.expires_at).getTime() <= Date.now() + REFRESH_SKEW_MS
+}
+
+// Outcome of a spawnKfactoryRefresh round-trip. We surface the discrete
+// failure modes (binary missing, refresh_token expired, generic error)
+// so the caller can decide whether to log once, log every time, or
+// surface a reattach prompt to the operator.
+interface RefreshOutcome {
+  status: "ok" | "not_logged_in" | "spawn_error" | "other_error"
+  stderr: string
+}
+
+// Spawn `kfactory auth refresh` and wait for it to exit. We capture
+// stderr (don't inherit it -- inheriting would let kfactory write raw
+// text into the TUI's alternate screen mid-render, corrupting it).
+// Exit codes from cmd/kfactory/auth.go::runAuthRefresh:
+//   0 = success (auth.json holds a fresh token)
+//   1 = errNotLoggedIn (refresh_token expired; operator must re-login)
+//   2 = other error (network, filesystem, Zitadel non-OK response)
+// child.on('error') fires for ENOENT (kfactory binary not on PATH) etc.
+function spawnKfactoryRefresh(): Promise<RefreshOutcome> {
+  return new Promise((resolve) => {
+    let child
+    try {
+      child = spawn("kfactory", ["auth", "refresh"], {
+        stdio: ["ignore", "ignore", "pipe"],
+      })
+    } catch (err) {
+      resolve({ status: "spawn_error", stderr: String(err) })
+      return
+    }
+    const chunks: Buffer[] = []
+    child.stderr?.on("data", (chunk: Buffer) => chunks.push(chunk))
+    const timer = setTimeout(() => {
+      child!.kill("SIGTERM")
+    }, REFRESH_TIMEOUT_MS)
+    child.on("exit", (code) => {
+      clearTimeout(timer)
+      const stderr = Buffer.concat(chunks).toString("utf8").trim()
+      if (code === 0) resolve({ status: "ok", stderr })
+      else if (code === 1) resolve({ status: "not_logged_in", stderr })
+      else resolve({ status: "other_error", stderr })
+    })
+    child.on("error", (err) => {
+      clearTimeout(timer)
+      resolve({ status: "spawn_error", stderr: String(err) })
+    })
+  })
+}
+
+function createBearerRefreshFetch(cachePath: string): typeof fetch {
+  let currentBearer = readAuthFile(cachePath).access_token
+  let refreshing: Promise<void> | null = null
+  // Log a given failure mode at most once per TUI session so the
+  // alternate screen isn't spammed on every request when kfactory is
+  // broken or the refresh_token is dead.
+  const logged: Record<RefreshOutcome["status"], boolean> = {
+    ok: true,
+    not_logged_in: false,
+    spawn_error: false,
+    other_error: false,
+  }
+
+  async function ensureFresh() {
+    if (refreshing) {
+      await refreshing
+      return
+    }
+    const auth = readAuthFile(cachePath)
+    if (!isExpired(auth)) {
+      currentBearer = auth.access_token
+      return
+    }
+    refreshing = (async () => {
+      try {
+        const outcome = await spawnKfactoryRefresh()
+        if (outcome.status !== "ok" && !logged[outcome.status]) {
+          logged[outcome.status] = true
+          const detail = stripVTControlCharacters(outcome.stderr)
+          for (const cb of refreshHintSubscribers) {
+            cb({ kind: outcome.status, detail })
+          }
+        }
+        // Re-read regardless of outcome: ok = fresh tokens, anything
+        // else = stale tokens, and the SDK's 401 path is the right
+        // signal for the operator to reattach.
+        const refreshed = readAuthFile(cachePath)
+        currentBearer = refreshed.access_token
+      } catch {
+        // Filesystem error reading auth.json -- leave currentBearer
+        // alone. Next request will retry.
+      } finally {
+        refreshing = null
+      }
+    })()
+    await refreshing
+  }
+
+  // Cast via unknown: our wrapper is the call-signature of fetch, but
+  // Bun's typeof fetch also requires a `preconnect` static method we
+  // don't replicate (the SDK never invokes it on a custom fetch).
+  return (async (input: Parameters<typeof fetch>[0], init?: Parameters<typeof fetch>[1]) => {
+    await ensureFresh()
+    // @WARNING: do NOT pass `init.headers` alone -- when `input` is a
+    //    Request (the openapi-ts SDK calls our fetch this way), `fetch`
+    //    treats init.headers as a full override and discards EVERY header
+    //    the Request was built with (Content-Type, Content-Length,
+    //    x-opencode-workspace, x-opencode-directory, etc). The worker then
+    //    sees a POST with no Content-Type and an unparseable body -> 400
+    //    `kind=Payload reason="Expected object, got undefined"`. Merge
+    //    Request headers FIRST, then init.headers, then our Authorization.
+    const merged = new Headers()
+    if (input instanceof Request) {
+      input.headers.forEach((v, k) => merged.set(k, v))
+    }
+    if (init?.headers) {
+      new Headers(init.headers).forEach((v, k) => merged.set(k, v))
+    }
+    merged.set("Authorization", `Bearer ${currentBearer}`)
+    return fetch(input, { ...init, headers: merged })
+  }) as unknown as typeof fetch
+}
 
