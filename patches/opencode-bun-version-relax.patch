Relax the bun-version check so nixpkgs's bun can build opencode.

opencode's build script enforces `^${packageManager}` from the root
package.json; nixpkgs lags upstream's bun pin (NixOS/nixpkgs#519796:
newer bun produced segfaulting downstream builds). This relaxes the
range to `>=1.3.13`. The "no new bun-API usage in the gap" safety
argument is re-verified on every opencode bump -- record in
docs/spec.md's "Four-patch opencode stack" decisions entry. Drop when
nixpkgs ships a bun satisfying upstream's pin.

diff --git a/packages/script/src/index.ts b/packages/script/src/index.ts
index d148ce0..5afb0f0 100644
--- a/packages/script/src/index.ts
+++ b/packages/script/src/index.ts
@@ -10,8 +10,11 @@ if (!expectedBunVersion) {
   throw new Error("packageManager field not found in root package.json")
 }
 
-// relax version requirement
-const expectedBunVersionRange = `^${expectedBunVersion}`
+// kfactory: relax the strict `^packageManager` range so the bun that
+// nixpkgs ships can build opencode. Safety is re-verified per bump in
+// docs/spec.md's "Four-patch opencode stack" entry (kfactory repo). Drop
+// this patch when nixpkgs ships a bun satisfying upstream's pin.
+const expectedBunVersionRange = `>=1.3.13`
 
 if (!semver.satisfies(process.versions.bun, expectedBunVersionRange)) {
   throw new Error(`This script requires bun@${expectedBunVersionRange}, but you are using bun@${process.versions.bun}`)
