+// kfactory: parse a workspace's current branch directly from .git/HEAD.
+// Avoids depending on Git.Service from this route's effect context
+// (which would widen RouteRequirements and break server.ts).
+//
+// .git/HEAD content shape:
+//   - "ref: refs/heads/main\n" -> branch "main"
+//   - "<40-char sha>\n"        -> detached HEAD -> undefined
+//   - no .git dir              -> broken / non-git workspace -> undefined
+function readBranchFromGitHead(directory: string): string | undefined {
+  try {
+    const head = fs.readFileSync(path.join(directory, ".git", "HEAD"), "utf8").trim()
+    const m = head.match(/^ref: refs\/heads\/(.+)$/)
+    return m ? m[1] : undefined
+  } catch {
+    return undefined
+  }
+}
+
+// kfactory: shell `git status --porcelain` against the workspace and
+// return whether the working tree is dirty (untracked or modified
+// files present). Used by `kfactory tick` in skip-if-dirty mode to
+// gate dispatches over uncommitted work.
+//
+// Heavier than readBranchFromGitHead (child process vs file read)
+// but still single-digit ms per row for typical repos. Acceptable
+// because /experimental/workspace is a cold-path endpoint
+// (operator-driven, not per-event). 5s timeout caps the worst case
+// (huge index, NFS-backed worktree, etc.) so a slow check can't
+// stall the list response indefinitely.
+//
+// `execFileSync` (not exec/spawnSync-shell) -- the directory is a
+// schema-validated value but staying out of shell parsing entirely
+// is the right baseline. Returns undefined on any failure (missing
+// .git, git binary absent, timeout); consumers fail-CLOSED on
+// undefined.
+function gitStatusDirty(directory: string): boolean | undefined {
+  try {
+    const out = child_process.execFileSync(
+      "git",
+      ["-C", directory, "status", "--porcelain"],
+      { stdio: ["ignore", "pipe", "ignore"], timeout: 5000 },
+    )
+    return out.toString().trim().length > 0
+  } catch {
+    return undefined
+  }
+}
