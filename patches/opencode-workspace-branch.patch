+// kfactory: parse a workspace's current branch directly from .git/HEAD.
+// Avoids depending on Git.Service from this route's effect context
+// (which would widen RouteRequirements and break server.ts).
+//
+// .git/HEAD content shape:
+//   - "ref: refs/heads/main\n" -> branch "main"
+//   - "<40-char sha>\n"        -> detached HEAD -> undefined
+//   - no .git dir              -> broken / non-git workspace -> undefined
+function readBranchFromGitHead(directory: string): string | undefined {
+  try {
+    const head = fs.readFileSync(path.join(directory, ".git", "HEAD"), "utf8").trim()
+    const m = head.match(/^ref: refs\/heads\/(.+)$/)
+    return m ? m[1] : undefined
+  } catch {
+    return undefined
+  }
+}
